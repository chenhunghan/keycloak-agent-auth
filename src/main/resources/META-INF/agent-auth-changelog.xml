<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet author="agent-auth" id="agent-auth-1.0.0-initial-schema">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="AGENT_AUTH_HOST"/></not>
        </preConditions>

        <createTable tableName="AGENT_AUTH_HOST">
            <column name="ID" type="VARCHAR(64)">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="PK_AGENT_AUTH_HOST"/>
            </column>
            <column name="STATUS" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="PAYLOAD" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="AGENT_AUTH_AGENT">
            <column name="ID" type="VARCHAR(36)">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="PK_AGENT_AUTH_AGENT"/>
            </column>
            <column name="HOST_ID" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="KEY_THUMBPRINT" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="STATUS" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="PAYLOAD" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="IDX_AGENT_AUTH_AGENT_HOST"
                     tableName="AGENT_AUTH_AGENT">
            <column name="HOST_ID"/>
        </createIndex>
        <createIndex indexName="IDX_AGENT_AUTH_AGENT_HOST_KEY"
                     tableName="AGENT_AUTH_AGENT">
            <column name="HOST_ID"/>
            <column name="KEY_THUMBPRINT"/>
        </createIndex>

        <createTable tableName="AGENT_AUTH_CAPABILITY">
            <column name="NAME" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="PK_AGENT_AUTH_CAPABILITY"/>
            </column>
            <column name="PAYLOAD" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="AGENT_AUTH_ROTATED_HOST">
            <column name="OLD_HOST_ID" type="VARCHAR(64)">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="PK_AGENT_AUTH_ROTATED_HOST"/>
            </column>
            <column name="NEW_HOST_ID" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="ROTATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!--
        Adds a queryable USER_ID column on hosts and agents to support AAP §2.6 (cascade revocation
        on Keycloak user deletion) without scanning the JSON payload. Intentionally additive and
        split from 1.0.0-initial-schema so Liquibase checksums on already-deployed databases remain
        valid. Nullable — not every host is linked. Preconditions guard against re-running on any
        environment that already ran this change under a different checksum lineage.
    -->
    <changeSet author="agent-auth" id="agent-auth-1.1.0-user-id">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AGENT_AUTH_HOST" columnName="USER_ID"/></not>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_HOST">
            <column name="USER_ID" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <createIndex indexName="IDX_AGENT_AUTH_HOST_USER"
                     tableName="AGENT_AUTH_HOST">
            <column name="USER_ID"/>
        </createIndex>
    </changeSet>

    <changeSet author="agent-auth" id="agent-auth-1.1.0-agent-user-id">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AGENT_AUTH_AGENT" columnName="USER_ID"/></not>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_AGENT">
            <column name="USER_ID" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <createIndex indexName="IDX_AGENT_AUTH_AGENT_USER"
                     tableName="AGENT_AUTH_AGENT">
            <column name="USER_ID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
