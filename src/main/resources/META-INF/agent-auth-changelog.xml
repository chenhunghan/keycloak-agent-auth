<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet author="agent-auth" id="agent-auth-1.0.0-initial-schema">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="AGENT_AUTH_HOST"/></not>
        </preConditions>

        <createTable tableName="AGENT_AUTH_HOST">
            <column name="ID" type="VARCHAR(64)">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="PK_AGENT_AUTH_HOST"/>
            </column>
            <column name="STATUS" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="PAYLOAD" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="AGENT_AUTH_AGENT">
            <column name="ID" type="VARCHAR(36)">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="PK_AGENT_AUTH_AGENT"/>
            </column>
            <column name="HOST_ID" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="KEY_THUMBPRINT" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="STATUS" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="PAYLOAD" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="IDX_AGENT_AUTH_AGENT_HOST"
                     tableName="AGENT_AUTH_AGENT">
            <column name="HOST_ID"/>
        </createIndex>
        <createIndex indexName="IDX_AGENT_AUTH_AGENT_HOST_KEY"
                     tableName="AGENT_AUTH_AGENT">
            <column name="HOST_ID"/>
            <column name="KEY_THUMBPRINT"/>
        </createIndex>

        <createTable tableName="AGENT_AUTH_CAPABILITY">
            <column name="NAME" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="PK_AGENT_AUTH_CAPABILITY"/>
            </column>
            <column name="PAYLOAD" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="AGENT_AUTH_ROTATED_HOST">
            <column name="OLD_HOST_ID" type="VARCHAR(64)">
                <constraints nullable="false" primaryKey="true"
                             primaryKeyName="PK_AGENT_AUTH_ROTATED_HOST"/>
            </column>
            <column name="NEW_HOST_ID" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="ROTATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!--
        Adds a queryable USER_ID column on hosts and agents to support AAP §2.6 (cascade revocation
        on Keycloak user deletion) without scanning the JSON payload. Intentionally additive and
        split from 1.0.0-initial-schema so Liquibase checksums on already-deployed databases remain
        valid. Nullable — not every host is linked. Preconditions guard against re-running on any
        environment that already ran this change under a different checksum lineage.
    -->
    <changeSet author="agent-auth" id="agent-auth-1.1.0-user-id">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AGENT_AUTH_HOST" columnName="USER_ID"/></not>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_HOST">
            <column name="USER_ID" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <createIndex indexName="IDX_AGENT_AUTH_HOST_USER"
                     tableName="AGENT_AUTH_HOST">
            <column name="USER_ID"/>
        </createIndex>
    </changeSet>

    <changeSet author="agent-auth" id="agent-auth-1.1.0-agent-user-id">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AGENT_AUTH_AGENT" columnName="USER_ID"/></not>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_AGENT">
            <column name="USER_ID" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <createIndex indexName="IDX_AGENT_AUTH_AGENT_USER"
                     tableName="AGENT_AUTH_AGENT">
            <column name="USER_ID"/>
        </createIndex>
    </changeSet>

    <!--
        Queryable USER_CODE column for the AAP §7.1 device-authorization approval flow. Agents in
        pending delegated registration carry a short human-typable code; the /verify endpoint looks
        the agent up by that code. Nullable — only pending-device-auth agents populate it; cleared
        once the agent transitions to a terminal state.
    -->
    <changeSet author="agent-auth" id="agent-auth-1.2.0-agent-user-code">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AGENT_AUTH_AGENT" columnName="USER_CODE"/></not>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_AGENT">
            <column name="USER_CODE" type="VARCHAR(16)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <createIndex indexName="IDX_AGENT_AUTH_AGENT_USER_CODE"
                     tableName="AGENT_AUTH_AGENT">
            <column name="USER_CODE"/>
        </createIndex>
    </changeSet>

    <!--
        Phase 3 of the multi-tenant authz plan: promote agent.agent_capability_grants from a JSON
        blob nested in AGENT_AUTH_AGENT.PAYLOAD into a normalized join table. The blob continues
        to be the source of truth for application reads in this phase; the grants table is a
        sync-on-write secondary index, populated by JpaStorage.putAgent. Phase 4's cascade and
        future Phase 6 reads can query this table by capability_name + status. Composite PK
        prevents duplicate grants per (agent, capability).
    -->
    <changeSet author="agent-auth" id="agent-auth-1.3.0-agent-grant">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="AGENT_AUTH_AGENT_GRANT"/></not>
        </preConditions>
        <createTable tableName="AGENT_AUTH_AGENT_GRANT">
            <column name="AGENT_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="CAPABILITY_NAME" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="STATUS" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="GRANTED_BY" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="REASON" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="CONSTRAINTS_JSON" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="AGENT_AUTH_AGENT_GRANT"
                       columnNames="AGENT_ID,CAPABILITY_NAME"
                       constraintName="PK_AGENT_AUTH_AGENT_GRANT"/>
        <createIndex indexName="IDX_AGENT_AUTH_AGENT_GRANT_CAP"
                     tableName="AGENT_AUTH_AGENT_GRANT">
            <column name="CAPABILITY_NAME"/>
            <column name="STATUS"/>
        </createIndex>
        <createIndex indexName="IDX_AGENT_AUTH_AGENT_GRANT_AGENT"
                     tableName="AGENT_AUTH_AGENT_GRANT">
            <column name="AGENT_ID"/>
            <column name="STATUS"/>
        </createIndex>
    </changeSet>

    <!--
        Phase 6a of the multi-tenant authz plan: promote AGENT_AUTH_CAPABILITY from a JSON-blob
        PAYLOAD column to typed columns. Pre-production schema, no existing data to migrate —
        the columns are added and the PAYLOAD column dropped in the same changeset. Phase 1's
        ORGANIZATION_ID and REQUIRED_ROLE get indexes for cap-list filter and Phase 4 cascade.
    -->
    <changeSet author="agent-auth" id="agent-auth-1.4.0-capability-typed-columns">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AGENT_AUTH_CAPABILITY" columnName="VISIBILITY"/></not>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_CAPABILITY">
            <column name="DESCRIPTION" type="VARCHAR(1024)">
                <constraints nullable="true"/>
            </column>
            <column name="LOCATION" type="VARCHAR(2048)">
                <constraints nullable="true"/>
            </column>
            <column name="VISIBILITY" type="VARCHAR(32)">
                <constraints nullable="true"/>
            </column>
            <column name="REQUIRES_APPROVAL" type="BOOLEAN">
                <constraints nullable="true"/>
            </column>
            <column name="AUTO_DENY" type="BOOLEAN">
                <constraints nullable="true"/>
            </column>
            <column name="WRITE_CAPABLE" type="BOOLEAN">
                <constraints nullable="true"/>
            </column>
            <column name="ORGANIZATION_ID" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
            <column name="REQUIRED_ROLE" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="INPUT_SCHEMA" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="OUTPUT_SCHEMA" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <createIndex indexName="IDX_AGENT_AUTH_CAPABILITY_ORG"
                     tableName="AGENT_AUTH_CAPABILITY">
            <column name="ORGANIZATION_ID"/>
        </createIndex>
        <createIndex indexName="IDX_AGENT_AUTH_CAPABILITY_ROLE"
                     tableName="AGENT_AUTH_CAPABILITY">
            <column name="REQUIRED_ROLE"/>
        </createIndex>
        <dropColumn tableName="AGENT_AUTH_CAPABILITY" columnName="PAYLOAD"/>
    </changeSet>

    <!--
        Phase 6b of the multi-tenant authz plan: promote AGENT_AUTH_HOST to typed columns.
        Pre-production schema, no migration. PUBLIC_KEY_JWK is the host's Ed25519 JWK, kept as
        TEXT because we never query its components. DEFAULT_CAPABILITY_GRANTS is a serialized
        list of {capability, status, constraints?} — promotion to a normalized table is left
        to a future iteration since it isn't yet on a hot query path.
    -->
    <changeSet author="agent-auth" id="agent-auth-1.4.0-host-typed-columns">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AGENT_AUTH_HOST" columnName="PUBLIC_KEY_JWK"/></not>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_HOST">
            <column name="PUBLIC_KEY_JWK" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="HOST_JWKS_URL" type="VARCHAR(2048)">
                <constraints nullable="true"/>
            </column>
            <column name="HOST_KID" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="NAME" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="DESCRIPTION" type="VARCHAR(1024)">
                <constraints nullable="true"/>
            </column>
            <column name="SERVICE_ACCOUNT_CLIENT_ID" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="DEFAULT_CAPABILITY_GRANTS" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="LAST_USED_AT" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <dropColumn tableName="AGENT_AUTH_HOST" columnName="PAYLOAD"/>
    </changeSet>

    <!--
        Phase 6c of the multi-tenant authz plan: promote AGENT_AUTH_AGENT to typed columns.
        Pre-production schema, no migration. Per-grant data lives in AGENT_AUTH_AGENT_GRANT
        (Phase 3) but the per-agent grants list is also kept here as JSON TEXT for the
        application read path that hasn't been swapped yet — that swap is Phase 6d (or later).
    -->
    <changeSet author="agent-auth" id="agent-auth-1.4.0-agent-typed-columns">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AGENT_AUTH_AGENT" columnName="MODE"/></not>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_AGENT">
            <column name="MODE" type="VARCHAR(32)">
                <constraints nullable="true"/>
            </column>
            <column name="NAME" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="AGENT_PUBLIC_KEY" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="AGENT_JWKS_URL" type="VARCHAR(2048)">
                <constraints nullable="true"/>
            </column>
            <column name="AGENT_KID" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="ACTIVATED_AT" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="EXPIRES_AT" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="LAST_USED_AT" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="SESSION_TTL_RESET_AT" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="MAX_LIFETIME_RESET_AT" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="ABSOLUTE_LIFETIME_ELAPSED" type="BOOLEAN">
                <constraints nullable="true"/>
            </column>
            <column name="APPROVAL" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="REASON" type="VARCHAR(1024)">
                <constraints nullable="true"/>
            </column>
            <column name="REJECTION_REASON" type="VARCHAR(1024)">
                <constraints nullable="true"/>
            </column>
            <column name="REVOCATION_REASON" type="VARCHAR(1024)">
                <constraints nullable="true"/>
            </column>
            <column name="AGENT_GRANTS" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <dropColumn tableName="AGENT_AUTH_AGENT" columnName="PAYLOAD"/>
    </changeSet>

    <!--
        AAP §3.1 host.default_capabilities: list of capability names auto-granted to delegated
        agents under this host (TOFU — populated as user/admin approvals land). Stored as
        serialized JSON string[]. Distinct from DEFAULT_CAPABILITY_GRANTS, which is a
        constraint-preserving snapshot of the most recent registration's grant set used by the
        reactivation flow.
    -->
    <changeSet author="agent-auth" id="agent-auth-1.5.0-host-default-capabilities">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AGENT_AUTH_HOST" columnName="DEFAULT_CAPABILITIES"/></not>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_HOST">
            <column name="DEFAULT_CAPABILITIES" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet author="agent-auth" id="agent-auth-1.6.0-agent-lifetime-budgets">
        <preConditions onFail="MARK_RAN">
            <and>
                <not><columnExists tableName="AGENT_AUTH_AGENT" columnName="MAX_LIFETIME_SECONDS"/></not>
                <not><columnExists tableName="AGENT_AUTH_AGENT" columnName="ABSOLUTE_LIFETIME_SECONDS"/></not>
            </and>
        </preConditions>
        <addColumn tableName="AGENT_AUTH_AGENT">
            <column name="MAX_LIFETIME_SECONDS" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="ABSOLUTE_LIFETIME_SECONDS" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
